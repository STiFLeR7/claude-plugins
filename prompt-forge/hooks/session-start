#!/usr/bin/env bash
# SessionStart hook for prompt-forge plugin

set -euo pipefail

# Determine plugin root directory
SCRIPT_DIR="$(cd "$(dirname "$0")" && pwd)"
PLUGIN_ROOT="$(cd "${SCRIPT_DIR}/.." && pwd)"

# Read prompt-forge content
prompt_forge_content=$(cat "${PLUGIN_ROOT}/skills/prompt-forge/SKILL.md" 2>&1 || echo "Error reading prompt-forge skill")

# Escape string for JSON embedding
escape_for_json() {
    local s="$1"
    s="${s//\\/\\\\}"
    s="${s//\"/\\\"}"
    s="${s//$'\n'/\\n}"
    s="${s//$'\r'/\\r}"
    s="${s//$'\t'/\\t}"
    printf '%s' "$s"
}

prompt_forge_escaped=$(escape_for_json "$prompt_forge_content")
session_context="<EXTREMELY_IMPORTANT>\nYou have prompt-forge capabilities. Use this whenever a developer wants help writing, improving, or refining prompts.\n\n**Below is the full content of your 'prompt-forge:prompt-forge' skill:**\n\n${prompt_forge_escaped}\n</EXTREMELY_IMPORTANT>"

# Output context injection as JSON.
if [ -n "${CURSOR_PLUGIN_ROOT:-}" ]; then
  printf '{\n  "additional_context": "%s"\n}\n' "$session_context"
elif [ -n "${CLAUDE_PLUGIN_ROOT:-}" ] && [ -z "${COPILOT_CLI:-}" ]; then
  printf '{\n  "hookSpecificOutput": {\n    "hookEventName": "SessionStart",\n    "additionalContext": "%s"\n  }\n}\n' "$session_context"
else
  printf '{\n  "additionalContext": "%s"\n}\n' "$session_context"
fi

exit 0
